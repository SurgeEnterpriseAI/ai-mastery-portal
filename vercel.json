{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma db push --skip-generate && next build",
  "functions": {
    "app/api/coach/chat/route.ts": { "maxDuration": 60 },
    "app/api/coach/recommend/route.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron/openings", "schedule": "0 6 */3 * *" }
  ]
}

# Copy to .env.local and fill in. The portal runs FULLY without any of these:
#   - no ANTHROPIC_API_KEY  -> a built-in demo coach answers (still streams)
#   - no RESEND/SMTP        -> emails go to the in-app Outbox
#   - no RAZORPAY keys      -> the paywall simulates a successful UPI payment
# Set them to go live.

# Session cookie signing secret (use a long random string in production)
PORTAL_SECRET=change-me-to-a-long-random-string

# --- Claude (the AI coach) ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (defaults to claude-opus-4-8)
COACH_MODEL=claude-opus-4-8

# --- Email: Resend (preferred) ---
RESEND_API_KEY=re_...
MAIL_FROM=AI Mastery <onboarding@yourdomain.com>

# --- Email: SMTP fallback (e.g. Hostinger), used only if RESEND_API_KEY is absent ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=trainer@surgesoftware.co.in
SMTP_PASS=your-mailbox-password
SMTP_FROM=AI Mastery <trainer@surgesoftware.co.in>

# --- Payments: Razorpay (UPI, cards, netbanking) ---
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=your-secret
# Set this in the Razorpay dashboard webhook config too
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
# Price of the Pro unlock, in paise (default 99900 = ₹999)
PRO_PRICE_PAISE=99900
PAY_CURRENCY=INR
